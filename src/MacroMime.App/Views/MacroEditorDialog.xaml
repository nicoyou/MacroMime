<Window x:Class="MacroMime.App.Views.MacroEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MacroMime.App.ViewModels"
        xmlns:views="clr-namespace:MacroMime.App.Views"
        Title="{Binding title}" Height="570" Width="860"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance vm:MacroEditorViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <views:InverseBooleanConverter x:Key="InverseBoolean"/>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="Z" Command="{Binding UndoCommand}"/>
    </Window.InputBindings>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="▶ テスト再生" Command="{Binding TestPlayCommand}" Width="100" Margin="0,0,6,0"/>
                <Button Content="■ 停止" Command="{Binding StopTestPlaybackCommand}" Width="80" Margin="0,0,6,0"/>
                <Separator Margin="6,0"/>
                <Button Content="↶ 元に戻す" Command="{Binding UndoCommand}" Width="100" Margin="0,0,6,0"/>
                <Button Content="➕ 行追加" Command="{Binding AddStepCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="⧉ 行複製" Command="{Binding DuplicateSelectedStepsCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="🗑 行削除" Command="{Binding DeleteSelectedStepsCommand}" Width="90"/>
                <Separator Margin="6,0"/>
                <TextBlock Text="{Binding TotalDurationText}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="* 変更あり" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Foreground="DarkOrange" FontWeight="Bold"
                       Visibility="{Binding isDirty, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- ステップ一覧 + 編集操作 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" x:Name="StepDataGrid" ItemsSource="{Binding StepRows}"
                          SelectedItem="{Binding SelectedStepRow}"
                          SelectionChanged="OnStepDataGridSelectionChanged"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          IsReadOnly="{Binding IsTestPlaying}" SelectionMode="Extended"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.InputBindings>
                        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedStepsCommand}"/>
                        <KeyBinding Modifiers="Ctrl" Key="D" Command="{Binding DuplicateSelectedStepsCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding index}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="待機 ms" Binding="{Binding DelayBeforeMs}" Width="80"/>
                        <DataGridTextColumn Header="内容" Binding="{Binding description}" Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Grid.Row="1" Margin="0,4,0,0" Foreground="Gray" TextWrapping="Wrap"
                           Text="ヒント: 待機 ms はセルをダブルクリックで編集。Ctrl / Shift クリックで複数行選択、Delete キーで選択行を削除、Ctrl+D で複製。行追加 / 行複製は選択行の直下へ挿入。"/>

                <!-- 操作結果 -->
                <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="{Binding OperationResultText}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OperationResultText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="350" Margin="10,0,0,0">
                <GroupBox Header="行を削除した時の待機時間の扱い" Padding="8">
                    <StackPanel>
                        <TextBlock Text="行削除と mouseMove 削除で共通の設定" TextWrapping="Wrap"
                                   Foreground="Gray" Margin="0,0,0,6"/>
                        <RadioButton Content="破棄する"
                                     IsChecked="{Binding AddRemovedDelayToNextStep, Converter={StaticResource InverseBoolean}}"/>
                        <RadioButton Content="次に残るステップへ加算" Margin="0,2,0,0"
                                     IsChecked="{Binding AddRemovedDelayToNextStep}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="不要なマウス移動の削除" Padding="8" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="ボタン押下中 ( ドラッグ ) 以外の mouseMove を全て削除します" TextWrapping="Wrap"
                                   Foreground="Gray" Margin="0,0,0,6"/>
                        <Button Content="実行" Width="80" HorizontalAlignment="Right"
                                Command="{Binding RemoveNonDragMouseMovesCommand}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="クリック開始までの時間を短縮" Padding="8" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="mouseDown の待機時間が対象" TextWrapping="Wrap"
                                   Foreground="Gray" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding MouseDownStatisticsText}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox Text="{Binding ClickCooldownThresholdMs, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" ms 以上を " VerticalAlignment="Center"/>
                            <TextBox Text="{Binding ClickCooldownNewDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" ms へ" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="実行" Width="80" HorizontalAlignment="Right"
                                Command="{Binding UnifyClickCooldownCommand}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="クリック時間の短縮" Padding="8" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="mouseUp の待機時間が対象" TextWrapping="Wrap"
                                   Foreground="Gray" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding MouseUpStatisticsText}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox Text="{Binding ClickDurationThresholdMs, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" ms 以上を " VerticalAlignment="Center"/>
                            <TextBox Text="{Binding ClickDurationNewDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" ms へ" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="実行" Width="80" HorizontalAlignment="Right"
                                Command="{Binding UnifyClickDurationCommand}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="スクロール開始までの時間を短縮" Padding="8" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="mouseWheel の待機時間が対象" TextWrapping="Wrap"
                                   Foreground="Gray" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding MouseWheelStatisticsText}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox Text="{Binding ScrollCooldownThresholdMs, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" ms 以上を " VerticalAlignment="Center"/>
                            <TextBox Text="{Binding ScrollCooldownNewDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" ms へ" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="実行" Width="80" HorizontalAlignment="Right"
                                Command="{Binding UnifyScrollCooldownCommand}"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 保存 / 破棄 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存して閉じる" Width="110" Margin="0,0,8,0"
                    Command="{Binding SaveAndCloseCommand}"/>
            <Button Content="破棄して閉じる" Width="110"
                    Command="{Binding DiscardAndCloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>
