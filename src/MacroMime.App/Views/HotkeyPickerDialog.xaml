<Window x:Class="MacroMime.App.Views.HotkeyPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ホットキー設定" Height="180" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" TextWrapping="Wrap"
                   Text="割り当てたいキーの組み合わせを押してください (例: Ctrl+Alt+1)。"/>
        <Border Grid.Row="1" Margin="0,12" Padding="10" Background="#F0F0F0" CornerRadius="4">
            <TextBlock x:Name="ChordText" FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center" Text="(未設定)"/>
        </Border>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="クリア" Width="80" Click="Clear_Click" Margin="0,0,8,0"/>
            <Button Content="OK" Width="80" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
